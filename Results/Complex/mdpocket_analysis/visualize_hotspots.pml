# MDpocket Hotspot Visualization — Myc-Max
# Generated by hotspot_intersection.py
# Load this in PyMOL: File > Run Script > visualize_hotspots.pml

# Load structure
load /home/marcel/Project1/MYC-MAX/MYC-MAX-500/charmm-gui/gromacs/rep1_frame250_protein.pdb, protein

# Style
hide everything, protein
show cartoon, protein
color grey80, protein
set cartoon_transparency, 0.4

# Core hotspot — present in ALL replicas (red)
select core_hotspot, (chain A and resi 913) or (chain A and resi 914) or (chain A and resi 917) or (chain A and resi 938) or (chain A and resi 940) or (chain A and resi 953) or (chain A and resi 956) or (chain B and resi 214) or (chain B and resi 218) or (chain B and resi 230) or (chain B and resi 238) or (chain B and resi 239) or (chain B and resi 240) or (chain B and resi 245) or (chain B and resi 248) or (chain B and resi 249) or (chain B and resi 252) or (chain B and resi 254) or (chain B and resi 257)
show sticks, core_hotspot
color red, core_hotspot
label core_hotspot and name CA, "%s %s" % (resn, resi)

# Partial hotspot — present in ≥2 replicas (orange)
select partial_hotspot, (chain A and resi 916) or (chain A and resi 930) or (chain A and resi 939) or (chain A and resi 945) or (chain A and resi 948) or (chain A and resi 949) or (chain A and resi 952) or (chain A and resi 960) or (chain B and resi 215) or (chain B and resi 217) or (chain B and resi 229) or (chain B and resi 232) or (chain B and resi 258)
show sticks, partial_hotspot
color orange, partial_hotspot

# Load frequency map for context
load /home/marcel/Project1/MYC-MAX/MYC-MAX-500/charmm-gui/mdpocket_correct_freq.dx, freq_map
isosurface pocket_surface, freq_map, 0.25
color tv_blue, pocket_surface
set transparency, 0.4, pocket_surface

# Zoom on hotspot
zoom core_hotspot
set ray_shadows, 0
bg_color black

# Legend in console
print "RED   = core hotspot (all replicas): 19 residues"
print "ORANGE = partial hotspot (2/3 replicas): 13 residues"
print "BLUE  = MDpocket frequency surface (>25% of simulation)"
